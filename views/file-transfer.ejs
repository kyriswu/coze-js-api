<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <% const pageSeo = (typeof seo !== 'undefined' && seo) ? seo : {}; %>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageSeo.title || '文件中转站' %></title>
  <meta name="description" content="<%= pageSeo.description || '基于 downloads 目录的现代文件中转与管理面板。' %>" />
  <meta name="keywords" content="<%= pageSeo.keywords || '文件上传,文件管理,中转站,downloads' %>" />
  <style>
    :root {
      --bg-0: #f6f7f2;
      --bg-1: #e8efe5;
      --panel: #ffffff;
      --panel-soft: #f5f8f4;
      --line: #d8dfd2;
      --text: #1b3124;
      --muted: #5f735f;
      --brand: #2f8f59;
      --brand-deep: #1f6d43;
      --accent: #0f766e;
      --warn: #b45309;
      --error: #b42318;
      --ok: #15803d;
      --radius: 18px;
      --shadow: 0 12px 36px rgba(30, 55, 36, 0.08);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      font-family: "LXGW WenKai", "Source Han Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      background:
        radial-gradient(circle at 0% 0%, #eff8d6 0%, transparent 34%),
        radial-gradient(circle at 100% 20%, #d9f3e4 0%, transparent 32%),
        linear-gradient(145deg, var(--bg-0), var(--bg-1));
    }

    .wrap {
      width: min(1240px, calc(100% - 28px));
      margin: 20px auto 36px;
      display: grid;
      gap: 14px;
    }

    .topbar {
      border-radius: calc(var(--radius) + 4px);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      background: linear-gradient(135deg, #ffffff 0%, #f4f8ef 70%, #edf8f6 100%);
      padding: 20px;
      position: relative;
      overflow: hidden;
    }

    .topbar::after {
      content: "";
      position: absolute;
      right: -20px;
      top: -40px;
      width: 210px;
      height: 210px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(47, 143, 89, 0.18), transparent 66%);
    }

    .title {
      margin: 0;
      font-size: 30px;
      line-height: 1.15;
      letter-spacing: 0.4px;
      position: relative;
      z-index: 1;
    }

    .desc {
      margin: 8px 0 0;
      color: var(--muted);
      line-height: 1.65;
      position: relative;
      z-index: 1;
    }

    .layout {
      display: grid;
      grid-template-columns: 330px minmax(0, 1fr);
      gap: 14px;
    }

    .panel {
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: var(--panel);
      box-shadow: var(--shadow);
    }

    .sidebar {
      padding: 14px;
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .section-title {
      margin: 0;
      font-size: 16px;
      font-weight: 700;
    }

    .dropzone {
      border: 1.5px dashed #95b8a4;
      border-radius: 14px;
      min-height: 142px;
      background: linear-gradient(180deg, #f8fcf7 0%, #eff7ef 100%);
      display: grid;
      place-items: center;
      text-align: center;
      color: #496254;
      padding: 12px;
      transition: all 0.2s ease;
      cursor: pointer;
    }

    .dropzone.active {
      border-color: var(--brand);
      background: linear-gradient(180deg, #eefbf2 0%, #e3f4ea 100%);
      transform: translateY(-1px);
    }

    .dropzone strong {
      font-size: 15px;
      display: block;
      margin-bottom: 4px;
    }

    .dropzone small {
      color: #5f735f;
      font-size: 12px;
      line-height: 1.5;
    }

    .input-hidden {
      display: none;
    }

    .button-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    button {
      border: 0;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      background: var(--brand);
      color: #fff;
      transition: all 0.16s ease;
    }

    button:hover {
      background: var(--brand-deep);
      transform: translateY(-1px);
    }

    button:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
    }

    .ghost {
      background: #edf4eb;
      color: #2f5f45;
    }

    .ghost:hover {
      background: #dfece2;
    }

    .danger {
      background: #fef2f2;
      color: #b42318;
    }

    .danger:hover {
      background: #fee4e2;
    }

    .status {
      min-height: 20px;
      margin: 0;
      font-size: 13px;
      color: var(--muted);
    }

    .status.ok { color: var(--ok); }
    .status.warn { color: var(--warn); }
    .status.error { color: var(--error); }

    .queue {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel-soft);
      max-height: 250px;
      overflow: auto;
    }

    .queue-item {
      padding: 10px;
      border-bottom: 1px solid #e5ece0;
      display: grid;
      gap: 6px;
    }

    .queue-item:last-child {
      border-bottom: 0;
    }

    .queue-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      font-size: 12px;
    }

    .queue-name {
      font-weight: 700;
      word-break: break-all;
    }

    .queue-size,
    .queue-state {
      color: var(--muted);
      white-space: nowrap;
    }

    .queue-state.success { color: var(--ok); }
    .queue-state.error { color: var(--error); }
    .queue-state.uploading { color: var(--warn); }

    .progress {
      height: 6px;
      border-radius: 999px;
      background: #d7e4d8;
      overflow: hidden;
    }

    .progress > span {
      display: block;
      height: 100%;
      width: 0;
      background: linear-gradient(90deg, var(--brand), var(--accent));
      transition: width 0.18s ease;
    }

    .queue-empty {
      padding: 14px;
      color: var(--muted);
      font-size: 13px;
      text-align: center;
    }

    .main {
      padding: 14px;
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .controls {
      display: grid;
      gap: 10px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fbfef8;
      padding: 12px;
    }

    .search-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 160px 150px;
      gap: 8px;
    }

    input[type="search"],
    select {
      width: 100%;
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 10px;
      font-size: 13px;
      color: var(--text);
      padding: 10px 11px;
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .chip {
      border: 1px solid #b8cfbf;
      border-radius: 999px;
      background: #fff;
      color: #335242;
      padding: 5px 10px;
      font-size: 12px;
      cursor: pointer;
      user-select: none;
      transition: all 0.14s ease;
    }

    .chip:hover {
      border-color: #8ab399;
      background: #f1f8f1;
    }

    .chip.active {
      color: #fff;
      background: var(--brand);
      border-color: var(--brand);
    }

    .meta {
      color: var(--muted);
      font-size: 13px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .overview {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      overflow: hidden;
    }

    .overview-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 8px 10px;
      background: #f7fcf8;
      border-bottom: 1px solid var(--line);
    }

    .overview-title {
      margin: 0;
      font-size: 13px;
      color: #2f5f45;
      font-weight: 700;
    }

    .overview-body {
      padding: 10px;
      display: grid;
      gap: 10px;
    }

    .overview.collapsed .overview-body {
      display: none;
    }

    .toggle-btn {
      padding: 6px 10px;
      font-size: 12px;
      border-radius: 8px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }

    .stat-card {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px;
      background: #f8fcf7;
      min-height: 72px;
    }

    .stat-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .stat-value {
      font-size: 22px;
      font-weight: 700;
      line-height: 1.15;
    }

    .stat-sub {
      font-size: 12px;
      color: #2f6f49;
      margin-top: 2px;
    }

    .chart-box {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      padding: 10px;
    }

    .chart-title {
      margin: 0 0 8px;
      font-size: 13px;
      color: var(--muted);
    }

    .chart-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 8px 0;
    }

    .hot-box {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      padding: 10px;
      display: grid;
      gap: 8px;
    }

    .hot-list {
      display: grid;
      gap: 6px;
    }

    .hot-item {
      border: 1px solid #e8ede5;
      border-radius: 10px;
      padding: 8px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 8px;
      align-items: center;
      background: #fbfef8;
    }

    .hot-name {
      font-size: 13px;
      font-weight: 700;
      word-break: break-all;
    }

    .hot-meta {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    .hot-rank {
      font-size: 12px;
      color: #2f6f49;
      font-weight: 700;
      border-radius: 999px;
      border: 1px solid #cfe2d2;
      padding: 3px 8px;
      white-space: nowrap;
    }

    .chart-tooltip {
      position: fixed;
      pointer-events: none;
      z-index: 99;
      background: #13251d;
      color: #fff;
      font-size: 12px;
      padding: 6px 8px;
      border-radius: 6px;
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.25);
      transform: translate(10px, -10px);
      white-space: nowrap;
      display: none;
    }

    .file-list {
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
      background: #fff;
    }

    .file-item {
      border-bottom: 1px solid #e8ede5;
      padding: 12px;
      display: grid;
      grid-template-columns: 130px minmax(0, 1fr) 220px;
      gap: 12px;
      align-items: center;
      animation: fadeIn 0.24s ease both;
    }

    .file-item:last-child {
      border-bottom: 0;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .preview-box {
      width: 130px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #f5faf5;
      overflow: hidden;
      min-height: 88px;
      display: grid;
      place-items: center;
    }

    .preview-image,
    .preview-video,
    .preview-pdf {
      width: 100%;
      display: block;
    }

    .preview-image,
    .preview-video {
      height: 88px;
      object-fit: cover;
      background: #e8efe5;
    }

    .preview-audio {
      width: 120px;
      height: 34px;
    }

    .preview-pdf {
      height: 102px;
      border: 0;
    }

    .preview-empty {
      font-size: 12px;
      color: var(--muted);
    }

    .file-name {
      font-size: 15px;
      font-weight: 700;
      margin: 0 0 6px;
      word-break: break-all;
    }

    .tag-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 6px;
    }

    .tag {
      background: #eef5eb;
      color: #41634e;
      border-radius: 999px;
      font-size: 11px;
      padding: 3px 8px;
      border: 1px solid #d1dfd3;
    }

    .time {
      font-size: 12px;
      color: var(--muted);
      display: grid;
      gap: 3px;
    }

    .action-column {
      display: grid;
      gap: 7px;
      justify-items: end;
    }

    .action-column button {
      width: 100%;
      max-width: 190px;
      text-align: center;
    }

    .empty {
      color: var(--muted);
      text-align: center;
      padding: 20px 10px;
    }

    .pager {
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: 12px;
      gap: 8px;
      flex-wrap: wrap;
    }

    .pager .button-row {
      width: auto;
      display: flex;
    }

    .hint {
      font-size: 12px;
      color: var(--muted);
      margin: 0;
      line-height: 1.55;
    }

    .drawer-mask {
      position: fixed;
      inset: 0;
      background: rgba(16, 34, 23, 0.28);
      z-index: 79;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .drawer-mask.open {
      opacity: 1;
      pointer-events: auto;
    }

    .detail-drawer {
      position: fixed;
      right: 0;
      top: 0;
      width: min(420px, 100vw);
      height: 100vh;
      border-left: 1px solid var(--line);
      background: #fbfef8;
      box-shadow: -14px 0 28px rgba(16, 34, 23, 0.12);
      z-index: 80;
      transform: translateX(100%);
      transition: transform 0.24s ease;
      display: grid;
      grid-template-rows: auto 1fr auto;
    }

    .detail-drawer.open {
      transform: translateX(0);
    }

    .drawer-head {
      padding: 14px;
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      background: #f4fbf5;
    }

    .drawer-title {
      margin: 0;
      font-size: 16px;
    }

    .drawer-content {
      padding: 14px;
      overflow: auto;
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .drawer-file-name {
      margin: 0;
      font-size: 18px;
      line-height: 1.35;
      word-break: break-all;
    }

    .drawer-preview {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      padding: 10px;
    }

    .drawer-grid {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      overflow: hidden;
    }

    .drawer-row {
      border-bottom: 1px solid #e8ede5;
      padding: 10px;
      display: grid;
      gap: 4px;
    }

    .drawer-row:last-child {
      border-bottom: 0;
    }

    .drawer-label {
      font-size: 12px;
      color: var(--muted);
    }

    .drawer-value {
      font-size: 13px;
      color: var(--text);
      word-break: break-all;
    }

    .drawer-foot {
      border-top: 1px solid var(--line);
      padding: 12px 14px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      background: #f5faf5;
    }

    .btn-icon {
      width: auto;
    }

    @media (max-width: 1080px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .file-item {
        grid-template-columns: 110px minmax(0, 1fr);
      }

      .action-column {
        grid-column: 1 / -1;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        justify-items: stretch;
      }

      .action-column button {
        max-width: none;
      }
    }

    @media (max-width: 760px) {
      .search-row {
        grid-template-columns: 1fr;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .file-item {
        grid-template-columns: 1fr;
      }

      .preview-box {
        width: 100%;
        max-width: 260px;
      }

      .detail-drawer {
        width: 100vw;
      }

      .drawer-foot {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="wrap">
    <section class="topbar panel">
      <h1 class="title">文件中转站</h1>
      <p class="desc">拖拽或批量上传文件到 <code>/downloads</code>，在同一面板内完成筛选、检索、预览和链接分发。</p>
    </section>

    <section class="layout">
      <aside class="panel sidebar">
        <h2 class="section-title">上传中枢</h2>
        <label id="dropzone" class="dropzone" for="uploadInput">
          <div>
            <strong>拖拽文件到这里</strong>
            <small>或点击选择文件，支持多文件队列上传与 Ctrl+V 粘贴</small>
          </div>
        </label>
        <input id="uploadInput" class="input-hidden" type="file" multiple />
        <div class="button-row">
          <button id="uploadBtn" type="button">开始上传</button>
          <button id="refreshBtn" class="ghost" type="button">刷新列表</button>
        </div>
        <p id="status" class="status"></p>
        <p class="hint">上传接口沿用现有 <code>POST /file-transfer/upload</code>；支持拖拽/选择/粘贴（Ctrl+V）入队；文件名冲突时服务端会自动追加序号。</p>

        <h3 class="section-title">上传队列</h3>
        <div id="queueList" class="queue">
          <div class="queue-empty">暂无待上传文件</div>
        </div>
      </aside>

      <section class="panel main">
        <div class="controls">
          <div class="search-row">
            <input id="searchInput" type="search" placeholder="按文件名搜索，回车执行" />
            <select id="sortSelect">
              <option value="updatedAt:desc">更新时间：新到旧</option>
              <option value="updatedAt:asc">更新时间：旧到新</option>
              <option value="size:desc">体积：大到小</option>
              <option value="size:asc">体积：小到大</option>
              <option value="name:asc">名称：A-Z</option>
              <option value="name:desc">名称：Z-A</option>
            </select>
            <select id="pageSizeSelect">
              <option value="10">每页 10</option>
              <option value="20" selected>每页 20</option>
              <option value="50">每页 50</option>
            </select>
          </div>
          <div id="typeChipRow" class="chip-row"></div>
        </div>

        <div class="meta">
          <span id="meta">加载中...</span>
          <span id="activeMeta"></span>
        </div>

        <section id="overviewSection" class="overview collapsed">
          <div class="overview-head">
            <p class="overview-title">数据概览（可展开）</p>
            <button id="overviewToggleBtn" type="button" class="ghost toggle-btn">展开</button>
          </div>
          <div class="overview-body">
            <div class="stats-grid">
              <article class="stat-card">
                <div class="stat-label">当前总文件数</div>
                <div id="statTotal" class="stat-value">0</div>
                <div class="stat-sub">来自 downloads 目录</div>
              </article>
              <article class="stat-card">
                <div class="stat-label">本页聚合体积</div>
                <div id="statPageSize" class="stat-value">0 B</div>
                <div class="stat-sub">用于快速体量感知</div>
              </article>
              <article class="stat-card">
                <div class="stat-label">主力文件类型</div>
                <div id="statTopType" class="stat-value">-</div>
                <div id="statTopTypeCount" class="stat-sub">暂无数据</div>
              </article>
              <article class="stat-card">
                <div class="stat-label">最近 24h 访问量</div>
                <div id="statAccess24h" class="stat-value">0</div>
                <div class="stat-sub">基于 Redis 实时聚合</div>
              </article>
            </div>

            <div class="chart-box">
              <p class="chart-title">最近 15 天文件创建数量（日）</p>
              <div id="recentChart"></div>
            </div>

            <div class="hot-box">
              <p class="chart-title">Top N 热门文件（按访问数）</p>
              <div id="hotList" class="hot-list">
                <div class="chart-empty">暂无数据</div>
              </div>
            </div>
          </div>
        </section>

        <div id="fileList" class="file-list">
          <div class="empty">加载中...</div>
        </div>

        <div class="pager">
          <span id="pagerInfo">第 1 / 1 页</span>
          <div class="button-row">
            <button id="prevBtn" class="ghost" type="button">上一页</button>
            <button id="nextBtn" class="ghost" type="button">下一页</button>
          </div>
        </div>
      </section>
    </section>
  </main>

  <div id="chartTooltip" class="chart-tooltip"></div>
  <div id="drawerMask" class="drawer-mask"></div>
  <aside id="detailDrawer" class="detail-drawer" aria-hidden="true">
    <div class="drawer-head">
      <h3 class="drawer-title">文件详情</h3>
      <button id="drawerCloseBtn" class="ghost btn-icon" type="button">关闭</button>
    </div>
    <div id="drawerContent" class="drawer-content">
      <p class="empty">请选择一个文件查看详情</p>
    </div>
    <div class="drawer-foot">
      <button id="drawerOpenBtn" class="ghost" type="button" disabled>打开</button>
      <button id="drawerCopyBtn" class="ghost" type="button" disabled>复制链接</button>
      <button id="drawerDeleteBtn" class="danger" type="button" disabled>删除</button>
    </div>
  </aside>

  <script>
    const uploadInput = document.getElementById('uploadInput');
    const dropzone = document.getElementById('dropzone');
    const uploadBtn = document.getElementById('uploadBtn');
    const refreshBtn = document.getElementById('refreshBtn');
    const queueListEl = document.getElementById('queueList');
    const searchInput = document.getElementById('searchInput');
    const sortSelectEl = document.getElementById('sortSelect');
    const pageSizeSelectEl = document.getElementById('pageSizeSelect');
    const typeChipRowEl = document.getElementById('typeChipRow');
    const statusEl = document.getElementById('status');
    const metaEl = document.getElementById('meta');
    const activeMetaEl = document.getElementById('activeMeta');
    const fileListEl = document.getElementById('fileList');
    const statTotalEl = document.getElementById('statTotal');
    const statPageSizeEl = document.getElementById('statPageSize');
    const statTopTypeEl = document.getElementById('statTopType');
    const statTopTypeCountEl = document.getElementById('statTopTypeCount');
    const statAccess24hEl = document.getElementById('statAccess24h');
    const overviewSectionEl = document.getElementById('overviewSection');
    const overviewToggleBtn = document.getElementById('overviewToggleBtn');
    const recentChartEl = document.getElementById('recentChart');
    const hotListEl = document.getElementById('hotList');
    const chartTooltipEl = document.getElementById('chartTooltip');
    const drawerMaskEl = document.getElementById('drawerMask');
    const detailDrawerEl = document.getElementById('detailDrawer');
    const drawerContentEl = document.getElementById('drawerContent');
    const drawerCloseBtn = document.getElementById('drawerCloseBtn');
    const drawerOpenBtn = document.getElementById('drawerOpenBtn');
    const drawerCopyBtn = document.getElementById('drawerCopyBtn');
    const drawerDeleteBtn = document.getElementById('drawerDeleteBtn');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const pagerInfo = document.getElementById('pagerInfo');

    const pageState = {
      page: 1,
      pageSize: 20,
      totalPages: 1,
      selectedType: 'all',
      isUploading: false,
    };

    const uploadQueue = [];
    let queueId = 0;
    let typeStatsCache = [];
    let currentFiles = [];
    let selectedFile = null;
    const CHUNK_SIZE = 8 * 1024 * 1024;
    const CHUNK_UPLOAD_THRESHOLD = 16 * 1024 * 1024;

    function escapeHtml(input) {
      return String(input || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatTypeName(type) {
      return type === 'no_ext' ? '无扩展名' : String(type || 'no_ext').toLowerCase();
    }

    function formatBytes(bytes) {
      const size = Number(bytes || 0);
      if (size < 1024) return `${size} B`;
      if (size < 1024 * 1024) return `${(size / 1024).toFixed(2)} KB`;
      if (size < 1024 * 1024 * 1024) return `${(size / 1024 / 1024).toFixed(2)} MB`;
      return `${(size / 1024 / 1024 / 1024).toFixed(2)} GB`;
    }

    function setStatus(message, level) {
      statusEl.className = `status ${level || ''}`;
      statusEl.textContent = message || '';
    }

    function getTypeBuckets(stats) {
      const base = [{ type: 'all', count: stats.reduce((sum, item) => sum + Number(item.count || 0), 0) }];
      return base.concat(stats.slice(0, 20));
    }

    function renderTypeChips() {
      const buckets = getTypeBuckets(typeStatsCache);
      typeChipRowEl.innerHTML = buckets.map((item) => {
        const type = String(item.type || 'all');
        const activeClass = pageState.selectedType === type ? 'active' : '';
        const label = type === 'all' ? '全部类型' : formatTypeName(type);
        return `<button type="button" class="chip ${activeClass}" data-type="${escapeHtml(type)}">${escapeHtml(label)} (${item.count || 0})</button>`;
      }).join('');

      const chips = typeChipRowEl.querySelectorAll('.chip');
      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          pageState.selectedType = chip.getAttribute('data-type') || 'all';
          loadFiles(1);
        });
      });
    }

    function renderRecentChart(points) {
      if (!Array.isArray(points) || points.length === 0) {
        recentChartEl.innerHTML = '<div class="chart-empty">暂无数据</div>';
        return;
      }

      const max = Math.max(...points.map((item) => Number(item.count || 0)), 1);
      const width = 920;
      const height = 188;
      const gap = 3;
      const barWidth = Math.max(3, Math.floor((width - gap * (points.length - 1)) / points.length));

      const bars = points.map((item, index) => {
        const count = Number(item.count || 0);
        const h = Math.round((count / max) * 136);
        const x = index * (barWidth + gap);
        const y = 150 - h;
        return `<rect class="chart-bar" data-date="${item.date}" data-count="${count}" x="${x}" y="${y}" width="${barWidth}" height="${h}" fill="#2f8f59" rx="2" />`;
      }).join('');

      recentChartEl.innerHTML = `
        <svg viewBox="0 0 ${width} ${height}" width="100%" height="188" role="img" aria-label="最近15天创建数量图表">
          <line x1="0" y1="150" x2="${width}" y2="150" stroke="#d8dfd2" />
          ${bars}
          <text x="0" y="172" font-size="11" fill="#5f735f">${points[0]?.date || ''}</text>
          <text x="${width - 86}" y="172" font-size="11" fill="#5f735f">${points[points.length - 1]?.date || ''}</text>
        </svg>
      `;

      const barNodes = recentChartEl.querySelectorAll('.chart-bar');
      barNodes.forEach((barNode) => {
        barNode.addEventListener('mouseenter', (event) => {
          const date = event.target?.getAttribute('data-date') || '';
          const count = event.target?.getAttribute('data-count') || '0';
          chartTooltipEl.textContent = `${date}：${count}`;
          chartTooltipEl.style.display = 'block';
        });
        barNode.addEventListener('mousemove', (event) => {
          chartTooltipEl.style.left = `${event.clientX}px`;
          chartTooltipEl.style.top = `${event.clientY}px`;
        });
        barNode.addEventListener('mouseleave', () => {
          chartTooltipEl.style.display = 'none';
        });
      });
    }

    function buildPreview(file) {
      const safeName = escapeHtml(file.name || '');
      const safeUrl = escapeHtml(file.url || '#');
      const rawType = String(file.fileType || 'no_ext').toLowerCase();

      if (['png', 'jpg', 'jpeg', 'gif', 'webp', 'bmp', 'svg', 'avif'].includes(rawType)) {
        return `<div class="preview-box"><img class="preview-image" src="${safeUrl}" alt="${safeName}" loading="lazy" /></div>`;
      }
      if (['mp4', 'webm', 'ogg', 'mov', 'm4v'].includes(rawType)) {
        return `<div class="preview-box"><video class="preview-video" src="${safeUrl}" controls preload="metadata" muted playsinline></video></div>`;
      }
      if (['mp3', 'wav', 'ogg', 'm4a', 'aac', 'flac'].includes(rawType)) {
        return `<div class="preview-box"><audio class="preview-audio" src="${safeUrl}" controls preload="none"></audio></div>`;
      }
      if (rawType === 'pdf') {
        return `<div class="preview-box"><iframe class="preview-pdf" src="${safeUrl}" loading="lazy" title="${safeName}"></iframe></div>`;
      }

      return '<div class="preview-box"><span class="preview-empty">不可预览</span></div>';
    }

    function getPreviewFamily(fileType) {
      const rawType = String(fileType || 'no_ext').toLowerCase();
      if (['png', 'jpg', 'jpeg', 'gif', 'webp', 'bmp', 'svg', 'avif'].includes(rawType)) return 'image';
      if (['mp4', 'webm', 'ogg', 'mov', 'm4v'].includes(rawType)) return 'video';
      if (['mp3', 'wav', 'ogg', 'm4a', 'aac', 'flac'].includes(rawType)) return 'audio';
      if (rawType === 'pdf') return 'pdf';
      return 'other';
    }

    function renderDrawer() {
      if (!selectedFile) {
        drawerContentEl.innerHTML = '<p class="empty">请选择一个文件查看详情</p>';
        drawerOpenBtn.disabled = true;
        drawerCopyBtn.disabled = true;
        drawerDeleteBtn.disabled = true;
        return;
      }

      const safeName = escapeHtml(selectedFile.name || '');
      const safeType = escapeHtml(formatTypeName(selectedFile.fileType || 'no_ext'));
      const safeUrl = escapeHtml(selectedFile.url || '#');
      const encodedName = encodeURIComponent(selectedFile.name || '');
      const created = selectedFile.createdAt ? new Date(selectedFile.createdAt).toLocaleString() : '-';
      const updated = selectedFile.updatedAt ? new Date(selectedFile.updatedAt).toLocaleString() : '-';
      const family = getPreviewFamily(selectedFile.fileType);
      const previewTag = family === 'image' ? '图片' : family === 'video' ? '视频' : family === 'audio' ? '音频' : family === 'pdf' ? 'PDF' : '通用文件';

      drawerContentEl.innerHTML = `
        <h4 class="drawer-file-name">${safeName}</h4>
        <div class="drawer-preview">
          ${buildPreview(selectedFile)}
        </div>
        <div class="drawer-grid">
          <div class="drawer-row">
            <span class="drawer-label">文件类型</span>
            <span class="drawer-value">${safeType}（${previewTag}）</span>
          </div>
          <div class="drawer-row">
            <span class="drawer-label">文件体积</span>
            <span class="drawer-value">${formatBytes(selectedFile.size)}</span>
          </div>
          <div class="drawer-row">
            <span class="drawer-label">访问次数</span>
            <span class="drawer-value">${Number(selectedFile.accessCount || 0)}</span>
          </div>
          <div class="drawer-row">
            <span class="drawer-label">创建时间</span>
            <span class="drawer-value">${escapeHtml(created)}</span>
          </div>
          <div class="drawer-row">
            <span class="drawer-label">更新时间</span>
            <span class="drawer-value">${escapeHtml(updated)}</span>
          </div>
          <div class="drawer-row">
            <span class="drawer-label">访问链接</span>
            <span class="drawer-value">${safeUrl}</span>
          </div>
          <div class="drawer-row">
            <span class="drawer-label">相对路径</span>
            <span class="drawer-value">/downloads/${escapeHtml(selectedFile.name || '')}</span>
          </div>
        </div>
      `;

      drawerOpenBtn.disabled = false;
      drawerOpenBtn.setAttribute('data-url', selectedFile.url || '#');
      drawerCopyBtn.disabled = false;
      drawerCopyBtn.setAttribute('data-url', selectedFile.url || '');
      drawerDeleteBtn.disabled = false;
      drawerDeleteBtn.setAttribute('data-name', encodedName);
    }

    function openDrawer(file) {
      selectedFile = file;
      renderDrawer();
      detailDrawerEl.classList.add('open');
      drawerMaskEl.classList.add('open');
      detailDrawerEl.setAttribute('aria-hidden', 'false');
    }

    function closeDrawer() {
      detailDrawerEl.classList.remove('open');
      drawerMaskEl.classList.remove('open');
      detailDrawerEl.setAttribute('aria-hidden', 'true');
    }

    function updateStats(files, total) {
      const pageBytes = files.reduce((sum, file) => sum + Number(file.size || 0), 0);
      statTotalEl.textContent = String(total || 0);
      statPageSizeEl.textContent = formatBytes(pageBytes);

      const topType = typeStatsCache[0];
      if (topType) {
        statTopTypeEl.textContent = formatTypeName(topType.type);
        statTopTypeCountEl.textContent = `${topType.count} 个文件`;
      } else {
        statTopTypeEl.textContent = '-';
        statTopTypeCountEl.textContent = '暂无数据';
      }
    }

    function renderHotTopN(items) {
      if (!Array.isArray(items) || items.length === 0) {
        hotListEl.innerHTML = '<div class="chart-empty">暂无数据</div>';
        return;
      }

      hotListEl.innerHTML = items.map((item, index) => {
        const safeName = escapeHtml(item.name || '');
        const typeText = escapeHtml(formatTypeName(item.fileType || 'no_ext'));
        const total = Number(item.accessCount || 0);
        const day = Number(item.access24h || 0);
        return `
          <article class="hot-item">
            <div>
              <div class="hot-name">${safeName}</div>
              <div class="hot-meta">类型 ${typeText} · 访问 ${total} · 24h ${day}</div>
            </div>
            <span class="hot-rank">TOP ${index + 1}</span>
          </article>
        `;
      }).join('');
    }

    function toggleOverviewSection() {
      const collapsed = overviewSectionEl.classList.toggle('collapsed');
      overviewToggleBtn.textContent = collapsed ? '展开' : '收起';
    }

    function renderFiles(files) {
      if (!Array.isArray(files) || files.length === 0) {
        fileListEl.innerHTML = '<div class="empty">暂无文件，先拖拽一个文件试试。</div>';
        return;
      }

      fileListEl.innerHTML = files.map((file) => {
        const safeName = escapeHtml(file.name || '');
        const safeType = escapeHtml(formatTypeName(file.fileType || 'no_ext'));
        const safeUrl = escapeHtml(file.url || '#');
        const created = file.createdAt ? new Date(file.createdAt).toLocaleString() : '-';
        const updated = file.updatedAt ? new Date(file.updatedAt).toLocaleString() : '-';
        return `
          <article class="file-item">
            ${buildPreview(file)}
            <div>
              <h3 class="file-name">${safeName}</h3>
              <div class="tag-row">
                <span class="tag">类型 ${safeType}</span>
                <span class="tag">大小 ${formatBytes(file.size)}</span>
                <span class="tag">访问 ${Number(file.accessCount || 0)}</span>
              </div>
              <div class="time">
                <span>创建：${escapeHtml(created)}</span>
                <span>更新：${escapeHtml(updated)}</span>
              </div>
            </div>
            <div class="action-column">
              <button type="button" class="ghost" data-action="detail" data-name="${encodeURIComponent(file.name || '')}">查看详情</button>
              <button type="button" class="ghost" data-action="open" data-url="${safeUrl}">打开文件</button>
              <button type="button" class="ghost" data-action="copy" data-url="${safeUrl}">复制链接</button>
              <button type="button" class="danger" data-action="delete" data-name="${encodeURIComponent(file.name || '')}">删除文件</button>
            </div>
          </article>
        `;
      }).join('');

      const actionButtons = fileListEl.querySelectorAll('button[data-action]');
      actionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const action = button.getAttribute('data-action');
          if (action === 'detail') {
            const encodedName = button.getAttribute('data-name') || '';
            const fileName = decodeURIComponent(encodedName);
            const file = currentFiles.find((item) => item.name === fileName);
            if (file) {
              openDrawer(file);
            }
            return;
          }
          if (action === 'open') {
            const url = button.getAttribute('data-url') || '#';
            window.open(url, '_blank', 'noopener');
            return;
          }
          if (action === 'copy') {
            const url = button.getAttribute('data-url') || '';
            copyLink(url);
            return;
          }
          if (action === 'delete') {
            const encodedName = button.getAttribute('data-name') || '';
            deleteFile(encodedName);
          }
        });
      });
    }

    function updatePager() {
      pagerInfo.textContent = `第 ${pageState.page} / ${pageState.totalPages} 页`;
      prevBtn.disabled = pageState.page <= 1;
      nextBtn.disabled = pageState.page >= pageState.totalPages;
    }

    function renderQueue() {
      if (uploadQueue.length === 0) {
        queueListEl.innerHTML = '<div class="queue-empty">暂无待上传文件</div>';
        return;
      }

      queueListEl.innerHTML = uploadQueue.map((item) => `
        <article class="queue-item">
          <div class="queue-head">
            <span class="queue-name">${escapeHtml(item.file.name)}</span>
            <span class="queue-size">${formatBytes(item.file.size)}</span>
          </div>
          <div class="progress"><span style="width: ${Math.min(100, Math.max(0, item.progress || 0))}%"></span></div>
          <div class="queue-head">
            <span class="queue-state ${escapeHtml(item.status)}">${escapeHtml(item.message || '待上传')}</span>
            <span class="queue-size">${Math.round(item.progress || 0)}%</span>
          </div>
        </article>
      `).join('');
    }

    function enqueueFiles(fileList) {
      const files = Array.from(fileList || []);
      if (!files.length) {
        return;
      }

      files.forEach((file) => {
        queueId += 1;
        uploadQueue.push({
          id: queueId,
          file,
          progress: 0,
          status: 'pending',
          message: '待上传',
        });
      });

      renderQueue();
      setStatus(`已加入 ${files.length} 个文件到上传队列`, 'ok');
    }

    function extractClipboardFiles(event) {
      const clipboardData = event?.clipboardData;
      if (!clipboardData) {
        return [];
      }

      const items = Array.from(clipboardData.items || []);
      const fromItems = items
        .filter((item) => item && item.kind === 'file')
        .map((item) => item.getAsFile())
        .filter((file) => file instanceof File);

      if (fromItems.length > 0) {
        return fromItems;
      }

      return Array.from(clipboardData.files || []);
    }

    function setupPasteUpload() {
      document.addEventListener('paste', (event) => {
        const files = extractClipboardFiles(event);
        if (!files.length) {
          return;
        }

        event.preventDefault();
        enqueueFiles(files);
        setStatus(`已从剪贴板加入 ${files.length} 个文件，点击“开始上传”继续`, 'ok');
      });
    }

    function buildUploadSessionId(file) {
      const safeName = String(file?.name || 'upload').replace(/[^a-zA-Z0-9._-]/g, '_').slice(0, 64) || 'upload';
      const sizePart = String(file?.size || 0);
      const mtimePart = String(file?.lastModified || 0);
      return `u_${safeName}_${sizePart}_${mtimePart}`;
    }

    async function fetchWithTimeout(url, options = {}, timeoutMs = 45000) {
      const controller = new AbortController();
      const timer = window.setTimeout(() => controller.abort(), timeoutMs);
      try {
        return await fetch(url, {
          ...options,
          signal: controller.signal,
        });
      } finally {
        window.clearTimeout(timer);
      }
    }

    async function completeChunkUploadWithRetry(uploadId, fileName, totalChunks, maxRetries = 2) {
      const params = new URLSearchParams({
        uploadId,
        filename: fileName,
        totalChunks: String(totalChunks),
      });

      let lastError = null;
      for (let attempt = 0; attempt <= maxRetries; attempt += 1) {
        try {
          const res = await fetchWithTimeout(`/file-transfer/upload/complete?${params.toString()}`, {
            method: 'POST',
          }, 60000);
          let payload = {};
          try {
            payload = await res.json();
          } catch (_) {
            payload = {};
          }
          if (!res.ok || payload.code !== 0) {
            throw new Error(payload.msg || '分片合并失败');
          }
          return payload;
        } catch (error) {
          lastError = error;
          if (attempt < maxRetries) {
            await new Promise((resolve) => window.setTimeout(resolve, (attempt + 1) * 900));
          }
        }
      }

      throw lastError || new Error('分片合并失败');
    }

    async function uploadFileInChunks(queueItem) {
      const file = queueItem.file;
      const uploadId = queueItem.uploadId || buildUploadSessionId(file);
      queueItem.uploadId = uploadId;
      const totalChunks = Math.max(1, Math.ceil(file.size / CHUNK_SIZE));

      for (let index = 0; index < totalChunks; index += 1) {
        const start = index * CHUNK_SIZE;
        const end = Math.min(file.size, start + CHUNK_SIZE);
        const chunk = file.slice(start, end);
        const chunkBuffer = await chunk.arrayBuffer();

        const params = new URLSearchParams({
          uploadId,
          filename: file.name,
          index: String(index),
          totalChunks: String(totalChunks),
        });

        const chunkRes = await fetch(`/file-transfer/upload/chunk?${params.toString()}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/octet-stream',
            'X-File-Name': encodeURIComponent(file.name),
          },
          body: chunkBuffer,
        });

        let chunkPayload = {};
        try {
          chunkPayload = await chunkRes.json();
        } catch (_) {
          chunkPayload = {};
        }
        if (!chunkRes.ok || chunkPayload.code !== 0) {
          throw new Error(chunkPayload.msg || `分片上传失败（第 ${index + 1} 片）`);
        }

        queueItem.progress = ((index + 1) / totalChunks) * 100;
        queueItem.status = 'uploading';
        queueItem.message = `上传中（${index + 1}/${totalChunks}）`;
        renderQueue();
      }

      return completeChunkUploadWithRetry(uploadId, file.name, totalChunks, 2);
    }

    function uploadSingleFile(queueItem) {
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        const uploadUrl = `/file-transfer/upload?filename=${encodeURIComponent(queueItem.file.name)}`;
        xhr.open('POST', uploadUrl);
        xhr.setRequestHeader('Content-Type', 'application/octet-stream');
        xhr.setRequestHeader('X-File-Name', encodeURIComponent(queueItem.file.name));

        xhr.upload.addEventListener('progress', (event) => {
          if (!event.lengthComputable) {
            return;
          }
          queueItem.progress = (event.loaded / event.total) * 100;
          queueItem.status = 'uploading';
          queueItem.message = '上传中';
          renderQueue();
        });

        xhr.addEventListener('load', () => {
          let payload = null;
          try {
            payload = JSON.parse(xhr.responseText || '{}');
          } catch (error) {
            payload = { code: -1, msg: '响应解析失败' };
          }

          if (xhr.status >= 200 && xhr.status < 300 && payload.code === 0) {
            queueItem.progress = 100;
            queueItem.status = 'success';
            queueItem.message = '上传成功';
            renderQueue();
            resolve(payload);
            return;
          }

          reject(new Error(payload.msg || '上传失败'));
        });

        xhr.addEventListener('error', () => {
          reject(new Error('上传失败：网络异常'));
        });

        xhr.send(queueItem.file);
      });
    }

    async function uploadQueuedFiles() {
      if (pageState.isUploading) {
        return;
      }

      const pendingItems = uploadQueue.filter((item) => item.status === 'pending' || item.status === 'error');
      if (!pendingItems.length) {
        setStatus('队列中没有待上传文件', 'warn');
        return;
      }

      pageState.isUploading = true;
      uploadBtn.disabled = true;
      let successCount = 0;
      let failCount = 0;

      for (const item of pendingItems) {
        try {
          item.status = 'uploading';
          item.message = '上传中';
          renderQueue();
          if (Number(item.file?.size || 0) >= CHUNK_UPLOAD_THRESHOLD) {
            await uploadFileInChunks(item);
            item.progress = 100;
            item.status = 'success';
            item.message = '上传成功';
            renderQueue();
          } else {
            await uploadSingleFile(item);
          }
          successCount += 1;
        } catch (error) {
          item.status = 'error';
          item.message = error.message || '上传失败';
          failCount += 1;
          renderQueue();
        }
      }

      pageState.isUploading = false;
      uploadBtn.disabled = false;
      setStatus(`上传完成：成功 ${successCount}，失败 ${failCount}`, failCount > 0 ? 'warn' : 'ok');
      await loadFiles(1);
    }

    async function copyLink(url) {
      try {
        await navigator.clipboard.writeText(String(url || ''));
        setStatus('链接已复制到剪贴板', 'ok');
      } catch (error) {
        setStatus('复制失败，请检查浏览器剪贴板权限', 'warn');
      }
    }

    async function deleteFile(encodedFileName) {
      const fileName = decodeURIComponent(String(encodedFileName || ''));
      const ok = window.confirm(`确认删除文件：${fileName}？`);
      if (!ok) {
        return;
      }

      try {
        const res = await fetch(`/file-transfer/file?filename=${encodeURIComponent(fileName)}`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
        });
        const payload = await res.json();
        if (!res.ok || payload.code !== 0) {
          throw new Error(payload.msg || '删除失败');
        }
        if (selectedFile && selectedFile.name === fileName) {
          selectedFile = null;
          renderDrawer();
          closeDrawer();
        }
        setStatus(`删除成功：${fileName}`, 'ok');
        await loadFiles(pageState.page);
      } catch (error) {
        setStatus(error.message || '删除失败', 'error');
      }
    }

    async function loadFiles(page = 1) {
      pageState.page = page;
      const search = searchInput.value.trim();
      const sortValue = String(sortSelectEl.value || 'updatedAt:desc');
      const [sortBy, sortOrder] = sortValue.split(':');
      const params = new URLSearchParams();

      if (search) {
        params.set('search', search);
      }
      params.set('fileType', pageState.selectedType || 'all');
      params.set('sortBy', sortBy || 'updatedAt');
      params.set('sortOrder', sortOrder || 'desc');
      params.set('page', String(pageState.page));
      params.set('pageSize', String(pageState.pageSize));
      params.set('topN', '8');

      try {
        const res = await fetch(`/file-transfer/files?${params.toString()}`);
        const payload = await res.json();
        if (!res.ok || payload.code !== 0) {
          throw new Error(payload.msg || '文件列表获取失败');
        }

        const files = payload?.data?.files || [];
        currentFiles = files;
        const total = payload?.data?.total || files.length;
        pageState.page = payload?.data?.page || pageState.page;
        pageState.totalPages = payload?.data?.totalPages || 1;

        typeStatsCache = Array.isArray(payload?.data?.typeStats) ? payload.data.typeStats : [];
        renderTypeChips();
        renderRecentChart(payload?.data?.recent15Days || payload?.data?.recent30Days || []);
        renderHotTopN(payload?.data?.hotTopN || []);
        renderFiles(files);
        updateStats(files, total);
        updatePager();

        statAccess24hEl.textContent = String(payload?.data?.accessStats?.totalAccess24h || 0);

        metaEl.textContent = `共 ${total} 个文件（每页 ${pageState.pageSize} 条）`;
        activeMetaEl.textContent = pageState.selectedType === 'all'
          ? '当前筛选：全部类型'
          : `当前筛选：${formatTypeName(pageState.selectedType)}`;
      } catch (error) {
        metaEl.textContent = '加载失败';
        activeMetaEl.textContent = '';
        pageState.totalPages = 1;
        updatePager();
        fileListEl.innerHTML = `<div class="empty">${escapeHtml(error.message || '加载失败')}</div>`;
        recentChartEl.innerHTML = '<div class="chart-empty">加载失败</div>';
        hotListEl.innerHTML = '<div class="chart-empty">加载失败</div>';
        statAccess24hEl.textContent = '0';
      }
    }

    function setupDropzone() {
      ['dragenter', 'dragover'].forEach((eventName) => {
        dropzone.addEventListener(eventName, (event) => {
          event.preventDefault();
          event.stopPropagation();
          dropzone.classList.add('active');
        });
      });

      ['dragleave', 'drop'].forEach((eventName) => {
        dropzone.addEventListener(eventName, (event) => {
          event.preventDefault();
          event.stopPropagation();
          dropzone.classList.remove('active');
        });
      });

      dropzone.addEventListener('drop', (event) => {
        const files = event.dataTransfer?.files;
        enqueueFiles(files);
      });
    }

    uploadInput.addEventListener('change', (event) => {
      enqueueFiles(event.target.files);
      uploadInput.value = '';
    });

    uploadBtn.addEventListener('click', uploadQueuedFiles);
    refreshBtn.addEventListener('click', () => loadFiles(1));
    searchInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        loadFiles(1);
      }
    });
    sortSelectEl.addEventListener('change', () => loadFiles(1));

    pageSizeSelectEl.addEventListener('change', () => {
      const pageSize = Number.parseInt(String(pageSizeSelectEl.value || '20'), 10);
      pageState.pageSize = Number.isNaN(pageSize) || pageSize < 1 ? 20 : pageSize;
      loadFiles(1);
    });

    prevBtn.addEventListener('click', () => {
      if (pageState.page > 1) {
        loadFiles(pageState.page - 1);
      }
    });

    nextBtn.addEventListener('click', () => {
      if (pageState.page < pageState.totalPages) {
        loadFiles(pageState.page + 1);
      }
    });

    drawerCloseBtn.addEventListener('click', closeDrawer);
    drawerMaskEl.addEventListener('click', closeDrawer);
    drawerOpenBtn.addEventListener('click', () => {
      const url = drawerOpenBtn.getAttribute('data-url') || '#';
      window.open(url, '_blank', 'noopener');
    });
    drawerCopyBtn.addEventListener('click', () => {
      const url = drawerCopyBtn.getAttribute('data-url') || '';
      copyLink(url);
    });
    drawerDeleteBtn.addEventListener('click', async () => {
      const encodedName = drawerDeleteBtn.getAttribute('data-name') || '';
      await deleteFile(encodedName);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeDrawer();
      }
    });

    overviewToggleBtn.addEventListener('click', toggleOverviewSection);

    setupDropzone();
    setupPasteUpload();
    renderQueue();
    renderDrawer();
    loadFiles(1);
  </script>
</body>
</html>
