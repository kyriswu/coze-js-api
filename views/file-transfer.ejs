<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <% const pageSeo = (typeof seo !== 'undefined' && seo) ? seo : {}; %>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageSeo.title || '文件中转站' %></title>
  <meta name="description" content="<%= pageSeo.description || '基于 downloads 目录的轻量文件中转站。' %>" />
  <meta name="keywords" content="<%= pageSeo.keywords || '文件上传,文件搜索,中转站,downloads' %>" />
  <style>
    :root {
      --bg: #f3f7ff;
      --card: #ffffff;
      --line: #d9e2f4;
      --text: #16314d;
      --muted: #58708d;
      --blue: #1d67ff;
      --blue-dark: #0f4fd4;
      --ok: #0f9d58;
      --warn: #b45309;
      --error: #b42318;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "HarmonyOS Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      color: var(--text);
      background: radial-gradient(circle at 0% 0%, #e8f2ff 0%, var(--bg) 52%, #f8fbff 100%);
    }

    .wrap {
      width: min(1080px, calc(100% - 32px));
      margin: 28px auto 56px;
    }

    .head {
      margin-bottom: 20px;
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: linear-gradient(135deg, #ffffff, #f7faff);
    }

    .head h1 {
      margin: 0 0 8px;
      font-size: 28px;
    }

    .desc {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .layout {
      display: grid;
      grid-template-columns: 320px minmax(0, 1fr);
      gap: 16px;
    }

    .card {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--card);
      padding: 16px;
    }

    .card h2 {
      margin: 0 0 12px;
      font-size: 18px;
    }

    .field {
      display: grid;
      gap: 8px;
      margin-bottom: 12px;
    }

    .field label {
      font-size: 14px;
      color: var(--muted);
      font-weight: 600;
    }

    input[type="file"],
    input[type="search"],
    select {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 14px;
      color: var(--text);
      background: #fff;
    }

    .row {
      display: flex;
      gap: 8px;
    }

    button {
      border: none;
      border-radius: 10px;
      padding: 10px 14px;
      color: #fff;
      background: var(--blue);
      font-weight: 600;
      cursor: pointer;
    }

    button:hover { background: var(--blue-dark); }
    button:disabled { opacity: 0.6; cursor: not-allowed; }

    .ghost {
      background: #eef3ff;
      color: #26456c;
    }

    .ghost:hover { background: #e3ecff; }

    .hint {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      margin: 0;
    }

    .status {
      min-height: 20px;
      font-size: 13px;
      margin-top: 6px;
    }

    .status.ok { color: var(--ok); }
    .status.warn { color: var(--warn); }
    .status.error { color: var(--error); }

    .meta {
      margin-bottom: 10px;
      color: var(--muted);
      font-size: 13px;
    }

    .list {
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    thead tr { background: #f3f7ff; }

    th, td {
      padding: 10px;
      border-bottom: 1px solid #ecf1fb;
      text-align: left;
      vertical-align: top;
    }

    th { color: #3d5673; font-weight: 700; }

    tr:last-child td { border-bottom: none; }

    .file-name {
      max-width: 260px;
      word-break: break-all;
      font-weight: 600;
    }

    .url-link {
      display: inline-block;
      max-width: 320px;
      color: var(--blue);
      word-break: break-all;
      text-decoration: none;
    }

    .url-link:hover { text-decoration: underline; }

    .empty {
      padding: 20px;
      color: var(--muted);
      text-align: center;
    }

    .badge-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 8px 0 12px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 9px;
      border-radius: 999px;
      background: #eef3ff;
      color: #355171;
      font-size: 12px;
    }

    .chart-box {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      padding: 10px;
      margin-bottom: 12px;
    }

    .chart-title {
      font-size: 13px;
      color: var(--muted);
      margin: 0 0 6px;
    }

    .chart-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 10px 0;
    }

    .danger {
      background: #fef2f2;
      color: #b42318;
    }

    .danger:hover {
      background: #fee4e2;
    }

    .pager {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      margin-top: 12px;
      color: var(--muted);
      font-size: 13px;
    }

    .pager button {
      padding: 7px 10px;
      border-radius: 8px;
      font-size: 12px;
    }

    @media (max-width: 920px) {
      .layout { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="wrap">
    <section class="head">
      <h1>文件中转站</h1>
      <p class="desc">基于 <code>/downloads</code> 目录的最简文件中转页：上传任意格式文件，查看/搜索文件，并获取每个文件的直接访问 URL。</p>
    </section>

    <section class="layout">
      <div class="card">
        <h2>上传文件</h2>
        <div class="field">
          <label for="uploadInput">选择任意格式文件</label>
          <input id="uploadInput" type="file" />
        </div>
        <div class="row">
          <button id="uploadBtn" type="button">上传</button>
          <button id="refreshBtn" class="ghost" type="button">刷新列表</button>
        </div>
        <p class="hint">上传后文件会保存到服务端 downloads 目录，URL 可直接访问。</p>
        <div id="status" class="status"></div>
      </div>

      <div class="card">
        <h2>文件列表</h2>
        <div class="field">
          <label for="searchInput">按文件名搜索</label>
          <input id="searchInput" type="search" placeholder="输入关键字后按回车" />
        </div>
        <div class="field">
          <label for="typeFilter">按文件类型筛选</label>
          <select id="typeFilter">
            <option value="all">全部类型</option>
          </select>
        </div>
        <div class="field">
          <label for="sortSelect">排序方式</label>
          <select id="sortSelect">
            <option value="updatedAt:desc">按更新时间（新到旧）</option>
            <option value="updatedAt:asc">按更新时间（旧到新）</option>
            <option value="size:desc">按文件大小（大到小）</option>
            <option value="size:asc">按文件大小（小到大）</option>
            <option value="name:asc">按文件名（A-Z）</option>
            <option value="name:desc">按文件名（Z-A）</option>
          </select>
        </div>
        <div class="meta" id="meta">加载中...</div>
        <div class="badge-wrap" id="typeStats"></div>
        <div class="chart-box">
          <p class="chart-title">最近 30 天文件创建数量（日）</p>
          <div id="recentChart"></div>
        </div>
        <div class="list">
          <table>
            <thead>
              <tr>
                <th>文件名</th>
                <th>类型</th>
                <th>大小</th>
                <th>创建时间</th>
                <th>更新时间</th>
                <th>访问 URL</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody id="tbody">
              <tr><td class="empty" colspan="7">加载中...</td></tr>
            </tbody>
          </table>
        </div>
        <div class="pager">
          <span id="pagerInfo">第 1 / 1 页</span>
          <button id="prevBtn" class="ghost" type="button">上一页</button>
          <button id="nextBtn" class="ghost" type="button">下一页</button>
        </div>
      </div>
    </section>
  </main>

  <script>
    const uploadInput = document.getElementById('uploadInput');
    const uploadBtn = document.getElementById('uploadBtn');
    const refreshBtn = document.getElementById('refreshBtn');
    const searchInput = document.getElementById('searchInput');
    const statusEl = document.getElementById('status');
    const metaEl = document.getElementById('meta');
    const tbodyEl = document.getElementById('tbody');
    const typeFilterEl = document.getElementById('typeFilter');
    const sortSelectEl = document.getElementById('sortSelect');
    const typeStatsEl = document.getElementById('typeStats');
    const recentChartEl = document.getElementById('recentChart');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const pagerInfo = document.getElementById('pagerInfo');

    const pageState = {
      page: 1,
      pageSize: 20,
      totalPages: 1,
    };

    let typeStatsCache = [];

    function formatTypeName(type) {
      return type === 'no_ext' ? '无扩展名' : type;
    }

    function formatBytes(bytes) {
      const size = Number(bytes || 0);
      if (size < 1024) return `${size} B`;
      if (size < 1024 * 1024) return `${(size / 1024).toFixed(2)} KB`;
      if (size < 1024 * 1024 * 1024) return `${(size / 1024 / 1024).toFixed(2)} MB`;
      return `${(size / 1024 / 1024 / 1024).toFixed(2)} GB`;
    }

    function setStatus(message, level) {
      statusEl.className = `status ${level || ''}`;
      statusEl.textContent = message || '';
    }

    function escapeHtml(input) {
      return String(input || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderTypeStats(stats) {
      if (!Array.isArray(stats) || stats.length === 0) {
        typeStatsEl.innerHTML = '<span class="badge">暂无类型数据</span>';
        return;
      }

      typeStatsEl.innerHTML = stats
        .slice(0, 12)
        .map((item) => `<span class="badge">${escapeHtml(formatTypeName(item.type))}: ${item.count}</span>`)
        .join('');
    }

    function renderRecentChart(points) {
      if (!Array.isArray(points) || points.length === 0) {
        recentChartEl.innerHTML = '<div class="chart-empty">暂无数据</div>';
        return;
      }

      const max = Math.max(...points.map((item) => Number(item.count || 0)), 1);
      const width = 720;
      const height = 180;
      const gap = 3;
      const barWidth = Math.max(2, Math.floor((width - gap * (points.length - 1)) / points.length));

      const bars = points.map((item, index) => {
        const count = Number(item.count || 0);
        const h = Math.round((count / max) * 140);
        const x = index * (barWidth + gap);
        const y = 150 - h;
        return `<rect x="${x}" y="${y}" width="${barWidth}" height="${h}" fill="#1d67ff"><title>${item.date}: ${count}</title></rect>`;
      }).join('');

      recentChartEl.innerHTML = `
        <svg viewBox="0 0 ${width} ${height}" width="100%" height="180" role="img" aria-label="最近30天创建数量图表">
          <line x1="0" y1="150" x2="${width}" y2="150" stroke="#d9e2f4" />
          ${bars}
          <text x="0" y="170" font-size="11" fill="#58708d">${points[0]?.date || ''}</text>
          <text x="${width - 78}" y="170" font-size="11" fill="#58708d">${points[points.length - 1]?.date || ''}</text>
        </svg>
      `;
    }

    async function deleteFile(encodedFileName) {
      const fileName = decodeURIComponent(String(encodedFileName || ''));
      const ok = window.confirm(`确认删除文件：${fileName}？`);
      if (!ok) {
        return;
      }

      try {
        const res = await fetch(`/file-transfer/file?filename=${encodeURIComponent(fileName)}`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
        });
        const payload = await res.json();
        if (!res.ok || payload.code !== 0) {
          throw new Error(payload.msg || '删除失败');
        }
        setStatus(`删除成功：${fileName}`, 'ok');
        await loadFiles(pageState.page);
      } catch (error) {
        setStatus(error.message || '删除失败', 'error');
      }
    }

    window.deleteTransferFile = deleteFile;

    function renderFiles(files) {
      if (!Array.isArray(files) || files.length === 0) {
        tbodyEl.innerHTML = '<tr><td class="empty" colspan="7">暂无文件</td></tr>';
        return;
      }

      tbodyEl.innerHTML = files.map((file) => {
        const safeName = escapeHtml(file.name || '');
        const safeUrl = escapeHtml(file.url || '#');
        const safeType = escapeHtml(formatTypeName(file.fileType || 'no_ext'));
        const created = file.createdAt ? new Date(file.createdAt).toLocaleString() : '-';
        const updated = file.updatedAt ? new Date(file.updatedAt).toLocaleString() : '-';
        return `
          <tr>
            <td class="file-name">${safeName}</td>
            <td>${safeType}</td>
            <td>${formatBytes(file.size)}</td>
            <td>${created}</td>
            <td>${updated}</td>
            <td>
              <a class="url-link" href="${safeUrl}" target="_blank" rel="noopener noreferrer">${safeUrl}</a>
            </td>
            <td>
              <button type="button" class="danger" onclick="deleteTransferFile('${encodeURIComponent(file.name || '')}')">删除</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function updatePager() {
      pagerInfo.textContent = `第 ${pageState.page} / ${pageState.totalPages} 页`;
      prevBtn.disabled = pageState.page <= 1;
      nextBtn.disabled = pageState.page >= pageState.totalPages;
    }

    async function loadFiles(page = 1) {
      pageState.page = page;
      const search = searchInput.value.trim();
      const params = new URLSearchParams();
      if (search) params.set('search', search);
      const selectedType = typeFilterEl.value || 'all';
      const sortValue = String(sortSelectEl.value || 'updatedAt:desc');
      const [sortBy, sortOrder] = sortValue.split(':');
      params.set('fileType', selectedType);
      params.set('sortBy', sortBy || 'updatedAt');
      params.set('sortOrder', sortOrder || 'desc');
      params.set('page', String(pageState.page));
      params.set('pageSize', String(pageState.pageSize));

      try {
        const res = await fetch(`/file-transfer/files?${params.toString()}`);
        const payload = await res.json();
        if (!res.ok || payload.code !== 0) {
          throw new Error(payload.msg || '文件列表获取失败');
        }

        const files = payload?.data?.files || [];
        const total = payload?.data?.total || files.length;
        pageState.page = payload?.data?.page || pageState.page;
        pageState.totalPages = payload?.data?.totalPages || 1;
        metaEl.textContent = `共 ${total} 个文件（每页 ${pageState.pageSize} 条）`;

        const incomingTypeStats = payload?.data?.typeStats || [];
        typeStatsCache = Array.isArray(incomingTypeStats) ? incomingTypeStats : [];
        renderTypeStats(typeStatsCache);

        const types = ['all', ...typeStatsCache.map((item) => item.type)];
        const uniqueTypes = Array.from(new Set(types));
        typeFilterEl.innerHTML = uniqueTypes
          .map((type) => `<option value="${escapeHtml(type)}">${type === 'all' ? '全部类型' : escapeHtml(formatTypeName(type))}</option>`)
          .join('');
        typeFilterEl.value = selectedType;

        renderRecentChart(payload?.data?.recent30Days || []);
        updatePager();
        renderFiles(files);
      } catch (error) {
        metaEl.textContent = '加载失败';
        pageState.totalPages = 1;
        updatePager();
        typeStatsEl.innerHTML = '';
        recentChartEl.innerHTML = '<div class="chart-empty">加载失败</div>';
        tbodyEl.innerHTML = `<tr><td class="empty" colspan="7">${error.message || '加载失败'}</td></tr>`;
      }
    }

    async function uploadCurrentFile() {
      const file = uploadInput.files && uploadInput.files[0];
      if (!file) {
        setStatus('请先选择文件', 'warn');
        return;
      }

      uploadBtn.disabled = true;
      setStatus('上传中...', 'warn');

      try {
        const arrayBuffer = await file.arrayBuffer();
        const uploadUrl = `/file-transfer/upload?filename=${encodeURIComponent(file.name)}`;
        const res = await fetch(uploadUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/octet-stream',
            'X-File-Name': encodeURIComponent(file.name),
          },
          body: arrayBuffer,
        });

        const payload = await res.json();
        if (!res.ok || payload.code !== 0) {
          throw new Error(payload.msg || '上传失败');
        }

        const fileUrl = payload?.data?.url || '';
        setStatus(`上传成功：${fileUrl}`, 'ok');
        await loadFiles(1);
      } catch (error) {
        setStatus(error.message || '上传失败', 'error');
      } finally {
        uploadBtn.disabled = false;
      }
    }

    uploadBtn.addEventListener('click', uploadCurrentFile);
    refreshBtn.addEventListener('click', () => loadFiles(1));
    searchInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        loadFiles(1);
      }
    });

    typeFilterEl.addEventListener('change', () => {
      loadFiles(1);
    });

    sortSelectEl.addEventListener('change', () => {
      loadFiles(1);
    });

    prevBtn.addEventListener('click', () => {
      if (pageState.page > 1) {
        loadFiles(pageState.page - 1);
      }
    });

    nextBtn.addEventListener('click', () => {
      if (pageState.page < pageState.totalPages) {
        loadFiles(pageState.page + 1);
      }
    });

    loadFiles(1);
  </script>
</body>
</html>
