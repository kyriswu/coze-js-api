  <script>
    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    const tabPanes = Array.from(document.querySelectorAll('.tab-pane'));

    function activateTab(targetId) {
      tabButtons.forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      tabPanes.forEach((p) => p.classList.remove('active'));

      const activeBtn = tabButtons.find((b) => b.getAttribute('data-tab') === targetId && !b.classList.contains('is-hidden'));
      const activePane = tabPanes.find((p) => p.id === targetId && p.style.display !== 'none');
      if (!activeBtn || !activePane) {
        return;
      }
      activeBtn.classList.add('active');
      activeBtn.setAttribute('aria-selected', 'true');
      activePane.classList.add('active');
    }

    // Tab switching
    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.classList.contains('is-hidden')) {
          return;
        }
        activateTab(btn.getAttribute('data-tab'));
      });
    });

    // Industry filtering
    const filterButtons = Array.from(document.querySelectorAll('[data-industry-filter]'));
    function applyIndustryFilter(mode) {
      filterButtons.forEach((btn) => btn.classList.toggle('active', btn.getAttribute('data-industry-filter') === mode));

      tabButtons.forEach((btn) => {
        const match = mode === 'all' || btn.getAttribute('data-industry') === mode;
        btn.classList.toggle('is-hidden', !match);
      });

      tabPanes.forEach((pane) => {
        const match = mode === 'all' || pane.getAttribute('data-industry') === mode;
        pane.style.display = match ? '' : 'none';
        if (!match) pane.classList.remove('active');
      });

      const currentVisibleActive = tabButtons.find((btn) => btn.classList.contains('active') && !btn.classList.contains('is-hidden'));
      if (currentVisibleActive) {
        activateTab(currentVisibleActive.getAttribute('data-tab'));
        return;
      }

      const firstVisible = tabButtons.find((btn) => !btn.classList.contains('is-hidden'));
      if (firstVisible) {
        activateTab(firstVisible.getAttribute('data-tab'));
      }
    }

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        applyIndustryFilter(btn.getAttribute('data-industry-filter'));
      });
    });

    applyIndustryFilter('all');

    // Copy prompt
    document.querySelectorAll('[data-copy-target]').forEach((button) => {
      button.addEventListener('click', async () => {
        const target = document.getElementById(button.getAttribute('data-copy-target'));
        if (!target) return;
        const originalText = button.textContent;
        try {
          await navigator.clipboard.writeText(target.textContent.trim());
          button.textContent = '✓ 已复制';
        } catch {
          button.textContent = '复制失败';
        }
        window.setTimeout(() => { button.textContent = originalText; }, 1800);
      });
    });
  </script>
